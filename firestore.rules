rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isTeacher() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /grades/{gradeId} {
      allow read: if isAuthenticated() && (isAdmin() || isTeacher());
      allow write: if isAdmin() || (isTeacher() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['classCount']));
    }

    match /subjects/{subjectId} {
      allow read: if isAuthenticated() && (isAdmin() || isTeacher());
      allow write: if isAdmin() || (isTeacher() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['studentCount']));
    }

    match /classes/{classId} {
      allow read: if isAuthenticated() && (isAdmin() || isTeacher());
      allow create: if isAdmin() || (isTeacher() && request.resource.data.teacherId == request.auth.uid);
      allow update, delete: if isAdmin() || (isTeacher() && (resource.data.teacherId == request.auth.uid));
    }

    match /timetable/{document=**} {
      allow read: if isAuthenticated() && (isAdmin() || isTeacher());
      allow write: if isAdmin() || (isTeacher() && (resource.data.teacherId == request.auth.uid || request.resource.data.teacherId == request.auth.uid));
    }

    match /teachers/{teacherId} {
      allow read: if isAuthenticated() && (isAdmin() || isTeacher());
      allow write: if isAdmin() || (isTeacher() && request.auth.uid == teacherId);
    }

    match /students/{studentId} {
      // Teachers read rule requires filtering or validating enrolledClasses against teacher's classes which is complex in rules.
      // Easiest is to allow teachers read access and filter on the client, or check if intersection exists.
      allow read: if isAuthenticated() && (isAdmin() || isTeacher());
      allow write: if isAdmin() || (isTeacher() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['enrolledClasses', 'enrolledSubjects']));
    }

    match /payments/{document=**} {
      allow read, write: if isAdmin();
    }

    match /salaries/{salaryId} {
      allow read: if isAuthenticated() && (isAdmin() || (isTeacher() && resource.data.teacherId == request.auth.uid));
      allow create: if isAuthenticated() && (isAdmin() || (isTeacher() && request.resource.data.teacherId == request.auth.uid && request.resource.data.status == 'pending'));
      allow update, delete: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isAuthenticated() && (isAdmin() || isTeacher());
      allow write: if isAuthenticated() && (isAdmin() || (isTeacher() && request.resource.data.markedBy == request.auth.uid));
    }
  }
}
